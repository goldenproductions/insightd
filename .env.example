# === Insightd Configuration ===

# SMTP settings (required for email digest)
INSIGHTD_SMTP_HOST=smtp.gmail.com
INSIGHTD_SMTP_PORT=587
INSIGHTD_SMTP_USER=you@example.com
INSIGHTD_SMTP_PASS=your-app-password
INSIGHTD_SMTP_FROM=insightd@example.com

# Digest recipient
INSIGHTD_DIGEST_TO=you@example.com

# Digest schedule (cron expression, default: Monday 08:00)
INSIGHTD_DIGEST_CRON=0 8 * * 1

# Timezone (used for cron schedules)
TZ=UTC

# Collection interval in minutes (default: 5)
INSIGHTD_COLLECT_INTERVAL=5

# Disk warning threshold (percent, default: 85)
INSIGHTD_DISK_WARN_THRESHOLD=85

# Data directory (default: /data inside container)
# INSIGHTD_DATA_DIR=/data

# Host root mount point (default: /host)
# INSIGHTD_HOST_ROOT=/host

# Docker socket (default: /var/run/docker.sock)
# DOCKER_HOST=/var/run/docker.sock

# Update check schedule (default: daily at 03:00)
# INSIGHTD_UPDATE_CHECK_CRON=0 3 * * *

# === Web UI ===

# Enable web UI (default: true)
# INSIGHTD_WEB_ENABLED=true

# Web UI port (default: 3000)
# INSIGHTD_WEB_PORT=3000

# Web UI bind address (default: 0.0.0.0)
# INSIGHTD_WEB_HOST=0.0.0.0

# Admin password for settings page (if unset, settings page is hidden)
# INSIGHTD_ADMIN_PASSWORD=changeme

# External hostname for agent setup command (auto-detected from browser if unset)
# INSIGHTD_EXTERNAL_HOST=192.168.1.10

# === MQTT (hub mode) ===

# MQTT broker URL (if set, runs in hub mode; if empty, standalone mode)
# INSIGHTD_MQTT_URL=mqtt://localhost:1883
# INSIGHTD_MQTT_USER=insightd
# INSIGHTD_MQTT_PASS=secretpass

# Host ID (identifies this host in multi-host setups)
# INSIGHTD_HOST_ID=my-server

# === Alerts ===

# Enable real-time alerts (default: false)
# INSIGHTD_ALERTS_ENABLED=true

# Alert recipient (defaults to INSIGHTD_DIGEST_TO)
# INSIGHTD_ALERTS_TO=you@example.com

# Minutes between repeat alerts for the same issue (default: 60)
# INSIGHTD_ALERT_COOLDOWN=60

# Container alerts
# INSIGHTD_ALERT_DOWN=true           # Alert on container down (default: true)
# INSIGHTD_ALERT_CPU=90              # CPU threshold % (default: 90, 0 = disabled)
# INSIGHTD_ALERT_MEMORY=0            # Memory threshold MB (default: 0 = disabled)
# INSIGHTD_ALERT_RESTART=3           # Restart count in 30-min window (default: 3, 0 = disabled)
# INSIGHTD_ALERT_UNHEALTHY=true      # Alert on unhealthy containers (default: true)

# Host alerts
# INSIGHTD_ALERT_HOST_CPU=90         # Host CPU threshold % (default: 90)
# INSIGHTD_ALERT_HOST_MEMORY=0       # Host low available memory MB (default: 0 = disabled)
# INSIGHTD_ALERT_LOAD=0              # Host load average threshold (default: 0 = disabled)

# Disk alert
# INSIGHTD_ALERT_DISK=90             # Disk threshold % (default: 90, 0 = disabled)

# Exclude containers from alerts (comma-separated patterns, * = wildcard)
# INSIGHTD_ALERT_EXCLUDE=dev-*,test-*

# Endpoint alerts
# INSIGHTD_ALERT_ENDPOINT_DOWN=true   # Alert when endpoints go down (default: true)
# INSIGHTD_ALERT_ENDPOINT_FAILURES=3  # Consecutive failures before alerting (default: 3)

# === Log Tailing ===

# Default number of log lines to fetch (default: 100)
# INSIGHTD_LOG_LINES=100

# Max log lines cap on agent side (default: 1000)
# INSIGHTD_LOG_MAX_LINES=1000

# Hub timeout for MQTT log requests in ms (default: 15000)
# INSIGHTD_LOG_TIMEOUT=15000
