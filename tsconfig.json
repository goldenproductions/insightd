{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "shared/**/*.ts",
    "shared/**/*.js",
    "agent/src/**/*.ts",
    "agent/src/**/*.js",
    "hub/src/**/*.ts",
    "hub/src/**/*.js",
    "src/**/*.ts",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "hub/src/web/frontend",
    "hub/src/web/public",
    "dist",
    "tests"
  ]
}
