{
  "name": "insightd",
  "version": "1.0.0",
  "description": "Self-hosted server awareness tool — proactive digests, not dashboards",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "collect": "node -e \"require('./src/index.js')\"",
    "test": "tsx --test tests/**/*.test.js",
    "test:unit": "tsx --test tests/unit/*.test.js",
    "test:integration": "tsx --test tests/integration/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "monitoring",
    "docker",
    "digest",
    "homelab"
  ],
  "author": "goldenproductions",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dockerode": "^4.0.10",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^3.3.34",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "mqtt": "^5.15.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
